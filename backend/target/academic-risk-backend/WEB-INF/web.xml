<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee
         http://xmlns.jcp.org/xml/ns/javaee/web-app_3_1.xsd"
         version="3.1">

    <display-name>Academic Risk Analysis Backend</display-name>

    <!-- Database Initializer Listener -->
    <listener>
        <listener-class>com.academicrisks.dao.DatabaseInitializer</listener-class>
    </listener>

    <!-- CORS Filter -->
    <filter>
        <filter-name>CorsFilter</filter-name>
        <filter-class>com.academicrisks.filter.CorsFilter</filter-class>
    </filter>
    <filter-mapping>
        <filter-name>CorsFilter</filter-name>
        <url-pattern>/*</url-pattern>
    </filter-mapping>

    <!-- Auth Filter -->
    <filter>
        <filter-name>AuthFilter</filter-name>
        <filter-class>com.academicrisks.filter.AuthFilter</filter-class>
    </filter>
    <filter-mapping>
        <filter-name>AuthFilter</filter-name>
        <url-pattern>/api/*</url-pattern>
    </filter-mapping>

    <!-- Auth Servlet -->
    <servlet>
        <servlet-name>AuthServlet</servlet-name>
        <servlet-class>com.academicrisks.servlet.AuthServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>AuthServlet</servlet-name>
        <url-pattern>/api/auth/*</url-pattern>
    </servlet-mapping>

    <!-- Students Servlet -->
    <servlet>
        <servlet-name>StudentsServlet</servlet-name>
        <servlet-class>com.academicrisks.servlet.StudentsServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>StudentsServlet</servlet-name>
        <url-pattern>/api/students</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>StudentsServlet</servlet-name>
        <url-pattern>/api/students/*</url-pattern>
    </servlet-mapping>

    <!-- Student Stats Servlet -->
    <servlet>
        <servlet-name>StudentStatsServlet</servlet-name>
        <servlet-class>com.academicrisks.servlet.StudentStatsServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>StudentStatsServlet</servlet-name>
        <url-pattern>/api/students/stats</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>StudentStatsServlet</servlet-name>
        <url-pattern>/api/students/stats/*</url-pattern>
    </servlet-mapping>

</web-app>
